{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "rules": {
    "typescript/no-explicit-any": "error"
  },
  "plugins": ["typescript", "vue", "unicorn", "oxc"],
  "categories": {
    "correctness": "warn"
  },
  "env": {
    "builtin": true
  },
  "ignorePatterns": [
    "node_modules/**",
    "dist/**",
    "showcase-dist/**",
    "coverage/**",
    "playwright-report/**",
    ".vite/**"
  ],
  "overrides": [
    {
      "files": ["tests/**/*.{ts,tsx}", "*.config.ts", "*.config.mts"],
      "rules": {
        "no-unused-vars": "off"
      }
    }
  ]
}
