{
  "name": "thekdatepicker-vue",
  "version": "1.2.1",
  "description": "Vue wrapper for ThekDatePicker",
  "keywords": [
    "calendar",
    "date",
    "datepicker",
    "time",
    "vue"
  ],
  "homepage": "https://github.com/Thekster/ThekDatePicker#readme",
  "bugs": {
    "url": "https://github.com/Thekster/ThekDatePicker/issues"
  },
  "license": "MIT",
  "author": "thekster",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Thekster/ThekDatePicker.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/thekdatepicker-vue.umd.cjs",
  "module": "./dist/thekdatepicker-vue.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/thekdatepicker-vue.js",
      "require": "./dist/thekdatepicker-vue.umd.cjs"
    }
  },
  "scripts": {
    "build": "vite build && tsc",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --check",
    "format:write": "oxfmt --write",
    "prepublishOnly": "npm run build && npm run test:run"
  },
  "dependencies": {
    "thekdatepicker": "1.2.1"
  },
  "devDependencies": {
    "@types/node": "^25.2.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.1",
    "vitest": "^4.0.18",
    "vue": "^3.5.0"
  },
  "peerDependencies": {
    "thekdatepicker": "1.2.1",
    "vue": "^3.0.0 || ^4.0.0"
  }
}
